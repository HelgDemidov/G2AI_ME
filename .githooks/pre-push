#!/bin/sh
# Report-only memory-lint check before push — NEVER blocks the push (matches
# memory_lint.py's own report-only philosophy: visibility, not a gate).
# Activate once per clone (not automatic — hooksPath is a local git config,
# not something a commit can turn on for you):
#   git config core.hooksPath .githooks

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$REPO_ROOT" || exit 0
[ -f "pipeline/scripts/memory_lint.py" ] || exit 0

PYTHON=".venv/bin/python"
[ -x "$PYTHON" ] || PYTHON="python3"
command -v "$PYTHON" >/dev/null 2>&1 || exit 0

OUTPUT=$("$PYTHON" pipeline/scripts/memory_lint.py --include-commands 2>&1)
echo "$OUTPUT" | tail -1

if echo "$OUTPUT" | grep -q '\[WARNING\] `'; then
    echo "--- memory-lint: dead anchors found (report-only, NOT blocking push) ---"
    echo "$OUTPUT" | grep -B1 '\[WARNING\] `'
fi

exit 0
